{
  "expo": {
    "name": "Expo PWA Tools",
    "slug": "expo-pwa-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "web"],
    "scheme": "expo-pwa-tools",
    "assetBundlePatterns": ["**/*"],
    "experiments": {
      "baseUrl": "/PWAforMyself"
    },
    "ios": {
      "supportsTablet": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon-512.png",
      "name": "Expo PWA Tools",
      "shortName": "PWA Tools",
      "themeColor": "#23272e",
      "backgroundColor": "#23272e",
      "display": "standalone",
      "orientation": "portrait"
    }
  }
}
