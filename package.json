{
  "name": "expo-pwa",
  "version": "1.0.0",
  "private": true,
  "description": "Personal offline Expo PWA tool collection.",
  "main": "index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "export:web": "expo export --platform web && node scripts/copy-pwa-public.mjs",
    "build:web": "npm run export:web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DancerPizza/PWAforMyself.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/DancerPizza/PWAforMyself/issues"
  },
  "homepage": "https://dancerpizza.github.io/PWAforMyself/",
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "expo": "^56.0.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
